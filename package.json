{
	"name": "catmd",
	"version": "0.1.0",
	"description": "Terminal markdown renderer inspired by pi",
	"private": true,
	"type": "module",
	"bin": {
		"catmd": "./dist/cli.js"
	},
	"exports": {
		".": "./dist/index.js"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"test": "node --test --import tsx test/markdown.test.ts",
		"catmd": "tsx src/cli.ts",
		"start": "node dist/cli.js"
	},
	"dependencies": {
		"get-east-asian-width": "^1.3.0",
		"marked": "^15.0.12"
	},
	"devDependencies": {
		"@types/node": "^22.15.29",
		"tsx": "^4.19.4",
		"typescript": "^5.8.3"
	},
	"engines": {
		"node": ">=20"
	}
}
